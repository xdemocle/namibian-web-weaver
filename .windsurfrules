# Windsurf Rules Configuration

# Tech Stack
tech_stack:
  - vite
  - react
  - typescript
  - tailwindcss
  - shadcn-ui
  - react-router-dom
  - react-query

# Build Configuration
build:
  command: "npm run build"
  output_directory: "dist"
  dev_command: "npm run dev"
  node_version: "18"

# Ignore Patterns (based on .gitignore and common patterns)
ignore:
  - node_modules
  - dist
  - dist-ssr
  - *.local
  - .vscode/*
  - .idea
  - .DS_Store
  - *.suo
  - *.ntvs*
  - *.njsproj
  - *.sln
  - *.sw?
  - logs
  - *.log
  - npm-debug.log*
  - yarn-debug.log*
  - yarn-error.log*
  - pnpm-debug.log*
  - lerna-debug.log*
  - .env
  - .env.local
  - .env.development.local
  - .env.test.local
  - .env.production.local

# Environment Variables
environment:
  - NODE_ENV

# Dependencies
dependencies:
  install_command: "npm install"
  package_manager: "npm"